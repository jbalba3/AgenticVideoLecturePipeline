# Copy to `.env` locally (never commit `.env`).
#
# Required for the Gemini agents (vision + JSON) and default TTS:
GOOGLE_API_KEY=YOUR_KEY_HERE

# If Gemini billing/quota fails (429), you can run agent steps on OpenAI instead:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_AGENTS=gpt-4o-mini

# Optional overrides:
# GEMINI_MODEL_AGENTS=gemini-2.0-flash
# GEMINI_MODEL_TTS=gemini-2.5-flash-preview-tts
#
# TTS_PROVIDER=gemini|elevenlabs|edge
#
# ElevenLabs (only if TTS_PROVIDER=elevenlabs):
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
